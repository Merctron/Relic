# CDK build artifacts
cdk/node_modules/
cdk/cdk.out/
cdk/**/*.d.ts
cdk/**/*.js
cdk/**/*.js.map

# Private configuration and assets — never commit contents, only track .gitkeep
config/*
assets/*
!config/.gitkeep
!assets/.gitkeep

# SSH keys
*.pem

# Environment files
.env
.env.*

# macOS
.DS_Store

# Editor
.idea/
.vscode/
